<section id="recipes-panel" class="recipes-panel">
  {% if hasRecipes %}
    <ul class="recipe-list">
      {% for r in recipes %}
        {% include "partials/recipe-card.njk" %}
      {% endfor %}
    </ul>
  {% else %}
    <p class="empty">No recipes yet. Paste a URL above to get started.</p>
  {% endif %}
</section>
